# Auth (Google OAuth)
NUXT_SESSION_PASSWORD=at-least-32-characters-long-random-string
NUXT_OAUTH_GOOGLE_CLIENT_ID=your_google_client_id
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=your_google_client_secret

# Database (optional — defaults to local SQLite file at data/voice-linear.db)
# TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token

# API keys (Linear, Groq, ZAI) are now per-user.
# Each user configures their own keys from Config > API Keys.
